# Connexion Neon — utilise la "Pooled connection string" du dashboard Neon
# (nécessaire pour les fonctions serverless Vercel)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Secret utilisé pour signer les tokens de connexion — génère une valeur aléatoire longue
# ex: openssl rand -base64 48
JWT_SECRET="change-moi"

# --- Photos de profil (Vercel Blob) ---
# Créée automatiquement quand tu connectes un store "Blob" à ton projet Vercel
# (dashboard → Storage → Create Database → Blob). En local : `vercel env pull`.
BLOB_READ_WRITE_TOKEN=""

# --- Génération automatique de paris sportifs (optionnel) ---

# Sécurise les endpoints /api/cron/* — Vercel l'envoie automatiquement comme
# "Authorization: Bearer <CRON_SECRET>" quand il déclenche un Cron Job.
# Génère une valeur aléatoire, ex: openssl rand -hex 32
CRON_SECRET="change-moi-aussi"

# api-football.com — plan gratuit : 100 requêtes/jour
API_FOOTBALL_KEY=""

# api-basketball.com — même compte API-SPORTS que ci-dessus, clé séparée
API_BASKETBALL_KEY=""

# pandascore.co — lire la note sur leurs CGU dans le README avant utilisation
PANDASCORE_TOKEN=""
